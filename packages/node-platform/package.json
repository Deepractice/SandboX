{
  "name": "@sandboxxjs/node-platform",
  "version": "2.4.0",
  "description": "Node.js platform for sandboxxjs — spawn + fs + WebSocket",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sandboxxjs/core": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.0",
    "sandboxxjs": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
