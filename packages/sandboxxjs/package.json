{
  "name": "sandboxxjs",
  "version": "2.2.1",
  "description": "Sandbox abstraction framework — unified lifecycle for cloud and browser sandboxes",
  "keywords": [
    "sandbox",
    "execution",
    "webcontainer",
    "ai",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Deepractice/SandboX.git"
  },
  "homepage": "https://github.com/Deepractice/SandboX",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sandboxxjs/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
