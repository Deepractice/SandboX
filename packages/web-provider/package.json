{
  "name": "@sandboxxjs/web-provider",
  "version": "2.2.0",
  "description": "WebContainer provider for sandboxxjs — browser-based sandbox execution",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bootstrap": "./dist/bootstrap.js"
  },
  "scripts": {
    "build": "tsc && node build-bootstrap.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sandboxxjs/core": "workspace:*",
    "@webcontainer/api": "^1.6.1"
  },
  "devDependencies": {
    "esbuild": "^0.27.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
