{
  "name": "@sandboxxjs/web-provider",
  "version": "1.0.0",
  "description": "WebContainer provider for sandboxxjs — browser-based sandbox execution",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sandboxxjs/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
