{
  "name": "sandboxjs",
  "version": "0.0.1",
  "description": "SandboX - Unified sandbox lifecycle for AI agents",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "prepare": "lefthook install || true",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "author": "Deepractice",
  "license": "MIT",
  "packageManager": "bun@1.3.5",
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@types/node": "^24.9.2",
    "lefthook": "^1.13.6",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.0"
  }
}
